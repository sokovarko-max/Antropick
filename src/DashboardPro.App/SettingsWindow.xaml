<Window
    x:Class="DashboardPro.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="20">
        <StackPanel Spacing="14" MaxWidth="440" HorizontalAlignment="Left">

            <TextBlock Text="Настройки" FontSize="22" FontWeight="SemiBold" />

            <TextBlock Text="Панель" FontSize="15" FontWeight="SemiBold" Margin="0,6,0,0" />

            <StackPanel Spacing="4">
                <TextBlock Text="Ширина панели (px)" FontSize="12" />
                <NumberBox x:Name="WidthBox" Minimum="280" Maximum="700" SpinButtonPlacementMode="Compact" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Край экрана" FontSize="12" />
                <ComboBox x:Name="EdgeBox" MinWidth="200">
                    <ComboBoxItem Content="Справа" Tag="Right" />
                    <ComboBoxItem Content="Слева" Tag="Left" />
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Монитор (-1 — авто, 0 — первый)" FontSize="12" />
                <NumberBox x:Name="MonitorBox" Minimum="-1" Maximum="8" SpinButtonPlacementMode="Compact" />
            </StackPanel>

            <ToggleSwitch x:Name="TopmostToggle" Header="Поверх всех окон" />
            <ToggleSwitch x:Name="ReserveToggle" Header="Резервировать место на экране (AppBar)" />
            <ToggleSwitch x:Name="AutostartToggle" Header="Запускать при входе в Windows" />
            <ToggleSwitch x:Name="SwitchersToggle" Header="Показывать в Alt+Tab" />

            <StackPanel Spacing="4">
                <TextBlock Text="Материал фона" FontSize="12" />
                <ComboBox x:Name="BackdropBox" MinWidth="200">
                    <ComboBoxItem Content="Mica" Tag="Mica" />
                    <ComboBoxItem Content="Mica Alt" Tag="MicaAlt" />
                    <ComboBoxItem Content="Acrylic" Tag="Acrylic" />
                    <ComboBoxItem Content="Без эффекта" Tag="None" />
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Тема" FontSize="12" />
                <ComboBox x:Name="ThemeBox" MinWidth="200">
                    <ComboBoxItem Content="Как в системе" Tag="System" />
                    <ComboBoxItem Content="Светлая" Tag="Light" />
                    <ComboBoxItem Content="Тёмная" Tag="Dark" />
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Непрозрачность содержимого" FontSize="12" />
                <Slider x:Name="OpacitySlider" Minimum="50" Maximum="100" StepFrequency="5" />
            </StackPanel>

            <TextBlock Text="Источники данных" FontSize="15" FontWeight="SemiBold" Margin="0,10,0,0" />

            <StackPanel Spacing="4">
                <TextBlock Text="Задачи" FontSize="12" />
                <ComboBox x:Name="TaskSourceBox" MinWidth="200" SelectionChanged="OnTaskSourceChanged">
                    <ComboBoxItem Content="База приложения" Tag="local" />
                    <ComboBoxItem Content="Markdown (файл или папка)" Tag="markdown" />
                    <ComboBoxItem Content="CSV-файл" Tag="csv" />
                    <ComboBoxItem Content="Todoist" Tag="todoist" />
                </ComboBox>
                <TextBox x:Name="TaskPathBox" Header="Путь к файлу/папке" PlaceholderText="C:\Notes\tasks.md" />
                <PasswordBox x:Name="TaskTokenBox" Header="API-токен Todoist" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Календарь" FontSize="12" />
                <ComboBox x:Name="CalendarSourceBox" MinWidth="200">
                    <ComboBoxItem Content="Не подключён" Tag="none" />
                    <ComboBoxItem Content="ICS-ссылка или файл (Google / Outlook)" Tag="ics" />
                </ComboBox>
                <TextBox x:Name="IcsUrlBox" Header="URL или путь к .ics"
                         PlaceholderText="https://calendar.google.com/calendar/ical/…/basic.ics" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Заметки" FontSize="12" />
                <ComboBox x:Name="NotesSourceBox" MinWidth="200">
                    <ComboBoxItem Content="База приложения" Tag="local" />
                    <ComboBoxItem Content="Папка Markdown (Obsidian)" Tag="markdown" />
                </ComboBox>
                <TextBox x:Name="NotesPathBox" Header="Папка с заметками" PlaceholderText="C:\Obsidian\Vault" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Обновление данных (минуты)" FontSize="12" />
                <NumberBox x:Name="RefreshBox" Minimum="1" Maximum="120" SpinButtonPlacementMode="Compact" />
            </StackPanel>

            <TextBlock Text="Модули" FontSize="15" FontWeight="SemiBold" Margin="0,10,0,0" />
            <StackPanel x:Name="ModulesPanel" Spacing="2" />

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,20">
                <Button x:Name="SaveButton" Content="Сохранить" Style="{StaticResource AccentButtonStyle}"
                        Click="OnSaveClick" />
                <Button Content="Закрыть" Click="OnCloseClick" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
