<UserControl
    x:Class="DashboardPro.App.Modules.WeatherModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="4">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock x:Name="TempText" FontSize="34" FontWeight="SemiLight" />
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="DescText" FontSize="13" />
                <TextBlock x:Name="CityText" Style="{StaticResource SecondaryTextStyle}" />
            </StackPanel>
        </StackPanel>
        <TextBlock x:Name="DetailsText" Style="{StaticResource SecondaryTextStyle}" />
        <TextBlock x:Name="ErrorText" Style="{StaticResource SecondaryTextStyle}" Visibility="Collapsed" />
    </StackPanel>
</UserControl>
