<UserControl
    x:Class="DashboardPro.App.Modules.PomodoroModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="6">
        <TextBlock x:Name="PhaseText" Style="{StaticResource SecondaryTextStyle}" />
        <TextBlock x:Name="TimeText" FontSize="38" FontWeight="SemiLight" />
        <ProgressBar x:Name="Progress" Minimum="0" Maximum="1" />
        <StackPanel Orientation="Horizontal" Spacing="6">
            <Button x:Name="StartPauseButton" Content="Старт" Click="OnStartPauseClick"
                    Style="{StaticResource AccentButtonStyle}" />
            <Button Content="Пропустить" Click="OnSkipClick" />
            <Button Content="Сброс" Click="OnResetClick" />
        </StackPanel>
        <TextBlock x:Name="StatsText" Style="{StaticResource SecondaryTextStyle}" />
    </StackPanel>
</UserControl>
