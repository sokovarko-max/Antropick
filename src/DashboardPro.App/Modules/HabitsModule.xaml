<UserControl
    x:Class="DashboardPro.App.Modules.HabitsModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="6">
        <StackPanel x:Name="ListPanel" Spacing="6" />
        <Grid ColumnSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="NewHabitBox" PlaceholderText="Новая привычка…" KeyDown="OnNewHabitKeyDown" />
            <Button Grid.Column="1" Click="OnAddClick" ToolTipService.ToolTip="Добавить привычку">
                <FontIcon Glyph="&#xE710;" FontSize="12" />
            </Button>
        </Grid>
    </StackPanel>
</UserControl>
