<UserControl
    x:Class="DashboardPro.App.Modules.TimersModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="10">
        <!-- Секундомер -->
        <StackPanel Spacing="4">
            <TextBlock Text="Секундомер" Style="{StaticResource SecondaryTextStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="StopwatchText" Text="00:00.0" FontSize="24" FontWeight="SemiLight"
                           VerticalAlignment="Center" MinWidth="96" />
                <Button x:Name="StopwatchButton" Content="Старт" Click="OnStopwatchClick" />
                <Button Content="Сброс" Click="OnStopwatchResetClick" />
            </StackPanel>
        </StackPanel>

        <!-- Таймер обратного отсчёта -->
        <StackPanel Spacing="4">
            <TextBlock Text="Таймер" Style="{StaticResource SecondaryTextStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <NumberBox x:Name="MinutesBox" Value="10" Minimum="1" Maximum="480"
                           SpinButtonPlacementMode="Hidden" MinWidth="64" VerticalAlignment="Center" />
                <TextBlock x:Name="CountdownText" Text="" FontSize="24" FontWeight="SemiLight"
                           VerticalAlignment="Center" />
                <Button x:Name="CountdownButton" Content="Старт" Click="OnCountdownClick" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
